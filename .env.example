# App
AIRMEMORY_ENV=local
AIRMEMORY_DATASET=airmemory_demo
AIRMEMORY_WIKI_DIR=./wiki
AIRMEMORY_STATE_DIR=./.airmemory_state
AIRMEMORY_LOG_LEVEL=INFO
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Redis
REDIS_URL=redis://localhost:6379/0
AIRMEMORY_REDIS_STREAM=airmemory:events:airflow_failures
AIRMEMORY_REDIS_GROUP=airmemory-workers
AIRMEMORY_REDIS_CONSUMER=worker-1
AIRMEMORY_USE_LOCAL_QUEUE=1

# Cognee
AIRMEMORY_USE_REAL_COGNEE=0
COGNEE_DATASET=airmemory_demo
LLM_API_KEY=
OPENAI_API_KEY=

# Optional Cognee cache config if supported by the installed version
CACHING=true
CACHE_BACKEND=redis
CACHE_HOST=localhost
CACHE_PORT=6379

# LLM behavior
AIRMEMORY_LLM_PROVIDER=openai
AIRMEMORY_LLM_MODEL=gpt-4.1-mini
AIRMEMORY_USE_FAKE_LLM=true

# Demo
AIRMEMORY_DEMO_DATE=2026-07-01
AIRMEMORY_ENABLE_AIRFLOW=false

# Optional Postgres-backed Cognee storage (start with: docker compose up -d postgres)
DB_PROVIDER=postgres
VECTOR_DB_PROVIDER=pgvector
GRAPH_DATABASE_PROVIDER=postgres
CACHE_BACKEND=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cognee
DB_PASSWORD=cognee
DB_NAME=cognee_db
